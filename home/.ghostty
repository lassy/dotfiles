#===== Font =====
font-family = Ricty ShinDiminished
font-size = 16

#===== Theme =====
theme = Wez

# ===== Keybind =====
# Ghostty の終了を Cmd + G に変更
keybind = cmd+g=quit

# 背景の透過を Cmd + U で切り替え
keybind = cmd+u=toggle_background_opacity

# タブの切り替え Command + 左右キー
keybind = cmd+right=next_tab
keybind = cmd+left=previous_tab

# ペイン間の移動 Command + Shift + 矢印キー
keybind = cmd+shift+left=goto_split:left
keybind = cmd+shift+right=goto_split:right
keybind = cmd+shift+up=goto_split:top
keybind = cmd+shift+down=goto_split:bottom

#===== Window =====
# 水平パディング・垂直パディング・パディングバランス
# window-padding-x = 10
# window-padding-y = 10
# window-padding-balance = true

# 背景の透過度
background-opacity = 0.6

# Window を最大化して起動
maximize = true


#===== Input =====
# 選択した箇所を自動的にコピー
copy-on-select = clipboard

# URL のリンク化を有効にする
link-url = true
